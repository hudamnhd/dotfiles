opt="" theme=""
if [ -e ~/.config/rofi/themes/rofi-emoji.rasi ]; then
	opt="-theme"
	theme="rofi-emoji"
fi

chosen=$(printf '%s' "$emojis" | rofi -dmenu -i $opt $theme -p "" | cut -d" " -f1)

if [ -n "$chosen" ]; then
	#xdotool type "$chosen"
	printf "%s" "$chosen" | xclip -selection clipboard
	notify-send -t 2000 "$chosen copied to clipboard."
fi
