#!/bin/sh

DIR=$(dirname ${BASH_SOURCE[0]})

case $BLOCK_BUTTON in
	1) pavucontrol ;;
	2) $HOME/bin/pulse/pulseaudio_toggle_mute_all.sh & ;;
	3) notify-send  -t 2000 `pactl list sinks | grep '^[[:space:]]Volume:' | head -n $(( $SINK + 2 )) | tail -n 1 | sed -e 's,.* \([0-9][0-9]*\)%.*,\1,'` & ;;
	4) pactl set-sink-volume @DEFAULT_SINK@ +10% |notify-send  -t 2000 `pactl list sinks | grep '^[[:space:]]Volume:' | head -n $(( $SINK + 2 )) | tail -n 1 | sed -e 's,.* \([0-9][0-9]*\)%.*,\1,'`  & ;;
	5) pactl set-sink-volume @DEFAULT_SINK@ -10% |notify-send  -t 2000 `pactl list sinks | grep '^[[:space:]]Volume:' | head -n $(( $SINK + 2 )) | tail -n 1 | sed -e 's,.* \([0-9][0-9]*\)%.*,\1,'`  & ;;
	*) notify-send -t 2000 "vol $BLOCK_BUTTON" & ;;
esac
