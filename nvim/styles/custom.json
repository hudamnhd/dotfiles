{
	"document": {
		"block_prefix": "\n",
		"block_suffix": "\n",
		"color": "#cfd2d9",
		"margin": 2
	},
	"block_quote": {
		"indent": 1,
		"indent_token": "│ ",
		"color": "#db9fd5"
	},
	"paragraph": {},
	"list": {
		"level_indent": 2
	},
	"heading": {
		"block_suffix": "\n",
		"color": "#78bff0",
		"bold": true
	},
	"h1": {
		"prefix": "# "
	},
	"h2": {
		"prefix": "## "
	},
	"h3": {
		"prefix": "### "
	},
	"h4": {
		"prefix": "#### "
	},
	"h5": {
		"prefix": "##### "
	},
	"h6": {
		"prefix": "###### ",
		"bold": false
	},
	"text": {},
	"strikethrough": {
		"crossed_out": true
	},
	"emph": {
		"italic": true,
		"color": "#d8af6a"
	},
	"strong": {
		"bold": true,
		"color": "#db9fd5"
	},
	"hr": {
		"color": "#b6b9c0",
		"format": "\n--------\n"
	},
	"item": {
		"block_prefix": "• "
	},
	"enumeration": {
		"block_prefix": ". "
	},
	"task": {
		"ticked": "[✓] ",
		"unticked": "[ ] "
	},
	"link": {
		"color": "#5dcaca",
		"underline": false
	},
	"link_text": {
		"color": "#cfd2d9",
		"bold": true
	},
	"image": {
		"color": "212",
		"underline": true
	},
	"image_text": {
		"color": "243",
		"format": "Image: {{.text}} →"
	},
	"code": {
		"prefix": " ",
		"suffix": " ",
		"color": "#f09d96",
		"background_color": "#383a3f"
	},
	"code_block": {
		"color": "244",
		"margin": 2,
		"chroma": {
			"text": {
				"color": "#cfd2d9"
			},
			"error": {
				"color": "#F1F1F1",
				"background_color": "#F05B5B"
			},
			"comment": {
				"color": "#8e9197"
			},
			"comment_preproc": {
				"color": "#FF875F"
			},
			"keyword": {
				"color": "#78bff0"
			},
			"keyword_reserved": {
				"color": "#FF5FD2"
			},
			"keyword_namespace": {
				"color": "#FF5F87"
			},
			"keyword_type": {
				"color": "#5dcaca"
			},
			"operator": {
				"color": "#cfd2d9"
			},
			"punctuation": {
				"color": "#5dcaca"
			},
			"name": {
				"color": "#cfd2d9"
			},
			"name_builtin": {
				"color": "#FF8EC7"
			},
			"name_tag": {
				"color": "#5dcaca"
			},
			"name_attribute": {
				"color": "#78bff0"
			},
			"name_class": {
				"color": "#F1F1F1",
				"underline": true,
				"bold": true
			},
			"name_constant": {},
			"name_decorator": {
				"color": "#78bff0"
			},
			"name_exception": {},
			"name_function": {
				"color": "#78bff0"
			},
			"name_other": {},
			"literal": {},
			"literal_number": {
				"color": "#cfd2d9"
			},
			"literal_date": {},
			"literal_string": {
				"color": "#74cba6"
			},
			"literal_string_escape": {
				"color": "#74cba6"
			},
			"generic_deleted": {
				"color": "#f09d96"
			},
			"generic_emph": {
				"italic": true
			},
			"generic_inserted": {
				"color": "#74cba6"
			},
			"generic_strong": {
				"bold": true
			},
			"generic_subheading": {
				"color": "#b6b9c0"
			},
			"background": {
				"background_color": "#373737"
			}
		}
	},
	"table": {},
	"definition_list": {},
	"definition_term": {},
	"definition_description": {
		"block_prefix": "\n🠶 "
	},
	"html_block": {},
	"html_span": {}
}
