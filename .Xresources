! ~/.Xresources configuration file
!-----------------------------------------------------------------------
! Base colors
*.foreground:   #D0D0D0
*.background:   #1A1A1A
*.cursorColor:  #FFFFFF

! Standard 16 terminal colors
*.color0:   #000000
*.color1:   #CC6666
*.color2:   #B5BD68
*.color3:   #F0C674
*.color4:   #81A2BE
*.color5:   #B294BB
*.color6:   #8ABEB7
*.color7:   #D0D0D0

*.color8:   #666666
*.color9:   #D54E53
*.color10:  #B9CA4A
*.color11:  #E7C547
*.color12:  #7AA6DA
*.color13:  #C397D8
*.color14:  #70C0B1
*.color15:  #EAEAEA

! Font
St.font:             AtkynsonMono Nerd Font:style=Regular:pixelsize=15:antialias=true:autohint=true

! Fallback fonts (max 8)
St.font_fallback1:  FiraCode Nerd Font:style=Retina:pixelsize=17:antialias=true:autohint=true
St.font_fallback2:  Symbola:size=13.5:antialias=true:autohint=true

! Borders in pixels
St.borderpx:        0

! Colors

St.foreground:   #D0D0D0
St.background:   #1A1A1A
St.reverseCursor: #1A1A1A
St.cursorColor:  #FFFFFF
St.bgUnfocused:  black
St.visualbellcolor: gray90

*St.color0:   #000000
*St.color1:   #CC6666
*St.color2:   #B5BD68
*St.color3:   #F0C674
*St.color4:   #81A2BE
*St.color5:   #B294BB
*St.color6:   #8ABEB7
*St.color7:   #D0D0D0

*St.color8:   #666666
*St.color9:   #D54E53
*St.color10:  #B9CA4A
*St.color11:  #E7C547
*St.color12:  #7AA6DA
*St.color13:  #C397D8
*St.color14:  #70C0B1
*St.color15:  #EAEAEA

! sxiv -----------------------------------------------------------------
sxiv.background:    #2E3440
sxiv.foreground:    #D8DEE9

! Xcursor settings -----------------------------------------------------
Xcursor.theme: Adwaita

! Xft settings ---------------------------------------------------------
Xft.dpi:       96
Xft.autohint:  0
Xft.lcdfilter: lcddefault
Xft.antialias: 1
Xft.rgba:      none
Xft.hinting:   1
Xft.hintstyle: hintfull
